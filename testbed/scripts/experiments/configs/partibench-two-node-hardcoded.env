EXPERIMENT_NAME="partibench-two-node-hardcoded"
CLUSTER_NAME="eab-pandora-testbed"
IMAGE_NAME="pandora-dnn:latest"
IMAGE_CONTEXT="PartiBench"
NODES_FILE="scripts/cluster-profiles/partibench-two-node.json"
PYTHON_BIN="${PYTHON_BIN:-python3}"

# Model to benchmark and place. Override at runtime:
#   PARTIBENCH_MODEL_NAME=vgg16 ./scripts/experiments/run.sh <this-file> benchmark
PARTIBENCH_MODEL_NAME="${PARTIBENCH_MODEL_NAME:-resnet152}"

# Block after which the split is made (0-indexed).
# Blocks 0..SPLIT_AFTER_BLOCK run on Edge; the rest run on Cloud.
# Override at runtime: SPLIT_AFTER_BLOCK=6 ./scripts/experiments/run.sh <this-file> run-place
SPLIT_AFTER_BLOCK="${SPLIT_AFTER_BLOCK:-3}"

BENCHMARK_HELPER="scripts/experiments/partibench/benchmark.sh"
BENCHMARK_HELPER_ARGS=("scripts/experiments/configs/partibench-two-node-hardcoded.env" "/tmp/partibench-benchmark.json")
BENCHMARK_OUTPUT_DIR="manifests/benchmark/output"
BENCHMARK_TARGETS=(
  "cloud"
  "edge"
)
BENCHMARK_JOB_MANIFESTS=(
  "manifests/benchmark/jobs/benchmark-cloud.yaml"
  "manifests/benchmark/jobs/benchmark-edge.yaml"
)
BENCHMARK_READER_MANIFESTS=(
  "manifests/benchmark/readers/reader-pod-cloud.yaml"
  "manifests/benchmark/readers/reader-pod-edge.yaml"
)

PLACE_HELPER="scripts/experiments/partibench/deploy_hardcoded_split.sh"
PLACE_HELPER_ARGS=("/tmp/partibench-benchmark.json" "${SPLIT_AFTER_BLOCK}" "${PARTIBENCH_MODEL_NAME}")

WORKER_MANIFESTS=(
  "manifests/services"
  "manifests/workers/two-node/edge-worker.yaml"
  "manifests/workers/two-node/cloud-worker.yaml"
)

ROLLOUT_TARGETS=(
  "edge:deployment/edge-worker"
  "cloud:deployment/cloud-worker"
)

LOG_TARGETS=(
  "edge:deployment/edge-worker"
  "cloud:deployment/cloud-worker"
  "edge:job/partibench-place"
)

STATUS_NAMESPACES=(
  "edge"
  "cloud"
)

RESET_JOBS=(
  "edge:partibench-place"
)

RESET_CONFIGMAPS=(
  "edge:partibench-place-config"
)

RESET_MANIFESTS=(
  "manifests/workers/two-node/edge-worker.yaml"
  "manifests/workers/two-node/cloud-worker.yaml"
  "manifests/services"
)
