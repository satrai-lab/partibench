EXPERIMENT_NAME="partibench-two-node-hardcoded"
CLUSTER_NAME="partibench-testbed"
IMAGE_NAME="partibench:latest"
IMAGE_CONTEXT=".."                    # build context = partibench/ root
DOCKERFILE="testbed/Dockerfile"    # relative to IMAGE_CONTEXT
NODES_FILE="scripts/cluster-profiles/partibench-two-node.json"
PYTHON_BIN="${PYTHON_BIN:-python3}"

# Model to benchmark and deploy.
# Override at runtime: PARTIBENCH_MODEL_NAME=vgg16 ./scripts/experiments/run.sh <cfg> benchmark
PARTIBENCH_MODEL_NAME="${PARTIBENCH_MODEL_NAME:-vgg16}"

# Block after which the split is made (0-indexed, inclusive).
# Blocks 0..SPLIT_AFTER_BLOCK run on edge; the rest run on cloud.
# Override at runtime: SPLIT_AFTER_BLOCK=6 ./scripts/experiments/run.sh <cfg> run-place
SPLIT_AFTER_BLOCK="${SPLIT_AFTER_BLOCK:-6}"

# ── Benchmark phase ────────────────────────────────────────────────────────────
BENCHMARK_HELPER="scripts/experiments/partibench/benchmark.sh"
BENCHMARK_HELPER_ARGS=(
  "scripts/experiments/configs/partibench-two-node-hardcoded.env"
  "/tmp/partibench-benchmark.json"
)
BENCHMARK_OUTPUT_DIR="manifests/benchmark/output"
BENCHMARK_TARGETS=("edge" "cloud")
BENCHMARK_JOB_MANIFESTS=(
  "manifests/benchmark/jobs/benchmark-edge.yaml"
  "manifests/benchmark/jobs/benchmark-cloud.yaml"
)
BENCHMARK_READER_MANIFESTS=(
  "manifests/benchmark/readers/reader-edge.yaml"
  "manifests/benchmark/readers/reader-cloud.yaml"
)

# ── Placement phase ────────────────────────────────────────────────────────────
PLACE_HELPER="scripts/experiments/partibench/deploy_hardcoded_split.sh"
PLACE_HELPER_ARGS=(
  "/tmp/partibench-benchmark.json"
  "${SPLIT_AFTER_BLOCK}"
  "${PARTIBENCH_MODEL_NAME}"
)

# ── Worker Deployments ────────────────────────────────────────────────────────
WORKER_MANIFESTS=(
  "manifests/services"
  "manifests/workers/initial-net-rules.yaml"
  "manifests/workers/edge-worker.yaml"
  "manifests/workers/cloud-worker.yaml"
)

ROLLOUT_TARGETS=(
  "edge:deployment/edge-worker"
  "cloud:deployment/cloud-worker"
)

LOG_TARGETS=(
  "edge:deployment/edge-worker"
  "cloud:deployment/cloud-worker"
  "edge:job/partibench-place"
)

STATUS_NAMESPACES=("edge" "cloud")

RESET_JOBS=("edge:partibench-place")
RESET_CONFIGMAPS=("edge:partibench-place-config")
RESET_MANIFESTS=(
  "manifests/workers/edge-worker.yaml"
  "manifests/workers/cloud-worker.yaml"
  "manifests/services"
)
