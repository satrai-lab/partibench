EXPERIMENT_NAME="partibench-three-node-auto"
CLUSTER_NAME="eab-pandora-testbed"
IMAGE_NAME="pandora-dnn:latest"
IMAGE_CONTEXT="PartiBench"
NODES_FILE="scripts/cluster-profiles/partibench-three-node-auto.json"
PYTHON_BIN="${PYTHON_BIN:-python3}"

# Model to benchmark and place. Override at runtime:
#   PARTIBENCH_MODEL_NAME=resnet152 ./scripts/experiments/run.sh <this-file> benchmark
PARTIBENCH_MODEL_NAME="${PARTIBENCH_MODEL_NAME:-vgg16}"

# Placement algorithm: "dp" (globally optimal) or "greedy" (fast, locally optimal).
# Override at runtime: AUTO_PLACE_METHOD=greedy ./scripts/experiments/run.sh <this-file> run-place
AUTO_PLACE_METHOD="${AUTO_PLACE_METHOD:-dp}"

BENCHMARK_HELPER="scripts/experiments/partibench/benchmark.sh"
BENCHMARK_HELPER_ARGS=("scripts/experiments/configs/partibench-three-node-auto.env" "/tmp/partibench-benchmark.json")
BENCHMARK_OUTPUT_DIR="manifests/benchmark/output"
BENCHMARK_TARGETS=(
  "iot"
  "edge"
  "cloud"
)
BENCHMARK_JOB_MANIFESTS=(
  "manifests/benchmark/jobs/benchmark-iot.yaml"
  "manifests/benchmark/jobs/benchmark-edge.yaml"
  "manifests/benchmark/jobs/benchmark-cloud.yaml"
)
BENCHMARK_READER_MANIFESTS=(
  "manifests/benchmark/readers/reader-pod-iot.yaml"
  "manifests/benchmark/readers/reader-pod-edge.yaml"
  "manifests/benchmark/readers/reader-pod-cloud.yaml"
)

PLACE_HELPER="scripts/experiments/partibench/deploy_auto.sh"
PLACE_HELPER_ARGS=("scripts/experiments/configs/partibench-three-node-auto.env" "/tmp/partibench-benchmark.json")
AUTO_PLACE_START_NODE="iot"
AUTO_PLACE_JOB_NAMESPACE="edge"
AUTO_PLACE_JOB_NAME="partibench-place"
AUTO_PLACE_CONFIGMAP_NAME="partibench-place-config"
AUTO_PLACE_JOB_MANIFEST="manifests/workers/three-node/place-job.yaml"
AUTO_PLACE_JOB_NODE_SELECTOR="Edge"
AUTO_PLACE_GRAPH_PATH="PartiBench/generated/three_node_auto/cc_graph.gml"

WORKER_MANIFESTS=(
  "manifests/services"
  "manifests/workers/three-node/iot-worker.yaml"
  "manifests/workers/three-node/edge-worker.yaml"
  "manifests/workers/three-node/cloud-worker.yaml"
)

ROLLOUT_TARGETS=(
  "iot:deployment/iot-worker"
  "edge:deployment/edge-worker"
  "cloud:deployment/cloud-worker"
)

LOG_TARGETS=(
  "iot:deployment/iot-worker"
  "edge:deployment/edge-worker"
  "cloud:deployment/cloud-worker"
  "edge:job/partibench-place"
)

STATUS_NAMESPACES=(
  "iot"
  "edge"
  "cloud"
)

RESET_JOBS=(
  "edge:partibench-place"
)

RESET_CONFIGMAPS=(
  "edge:partibench-place-config"
)

RESET_MANIFESTS=(
  "manifests/workers/three-node/iot-worker.yaml"
  "manifests/workers/three-node/edge-worker.yaml"
  "manifests/workers/three-node/cloud-worker.yaml"
  "manifests/services"
)
